{
  "manifest_version": 3,
  "name": "Readable Captions (可读字幕)",
  "version": "0.1.0",
  "description": "Turn captions into readable paragraphs.",
  "permissions": ["storage"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["options.html"],
      "matches": ["https://www.bilibili.com/*"]
    }
  ],
  "host_permissions": [
    "https://www.bilibili.com/*",
    "https://api.bilibili.com/*",
    "https://aisubtitle.hdslb.com/*",
    "https://*.hdslb.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.bilibili.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
