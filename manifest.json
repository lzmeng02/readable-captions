{
    "manifest_version": 3,
    "name": "Readable Captions (可读字幕)",
    "version": "0.2.0",
    "description": "Turn captions into readable paragraphs and AI summaries.",
    "permissions": ["storage"],
    "host_permissions": [
        "https://www.bilibili.com/*",
        "https://api.bilibili.com/*",
        "https://aisubtitle.hdslb.com/*",
        "https://*.hdslb.com/*",
        "https://api.openai.com/*"
    ],
    "content_scripts": [
        {
            "matches": ["https://www.bilibili.com/video/*"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ]
}
